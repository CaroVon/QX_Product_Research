# ============================================================
# QX Product Research Agent —— 环境变量配置模板
# 使用方法：cp .env.example .env  然后填入真实的 API Key
# ============================================================

# ─── 应用配置 ────────────────────────────────────────────────
DEBUG=true

# ─── 数据库 ──────────────────────────────────────────────────
# 本地开发推荐 SQLite（无需额外安装，开箱即用）
DATABASE_URL=sqlite+aiosqlite:///./local_dev.db

# 生产/Docker 使用 PostgreSQL（取消注释下面的配置，注释掉上面的 DATABASE_URL）
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=research_agent

# ─── Redis / Celery ──────────────────────────────────────────
# 不填则使用内存模式（任务同步执行，无需启动 Redis Worker）
# 生产环境启用 Redis 以支持真正的异步任务队列
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── 核心 API Keys（必填） ────────────────────────────────────
# DeepSeek 大模型 (LLM 文本生成)
# 申请：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Tavily 网络搜索
# 申请：https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firecrawl 网页内容抓取
# 申请：https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 可选：图像生成 ──────────────────────────────────────────
# 不填时封面使用 CSS 渐变兜底，不影响核心功能
# 申请：https://siliconflow.cn/
SILICONFLOW_API_KEY=
SILICONFLOW_IMAGE_MODEL=Tongyi-MAI/Z-Image-Turbo

# ─── 文件存储路径 ────────────────────────────────────────────
OUTPUT_DIR=./outputs
PDF_DOWNLOAD_BASE_URL=/api/v1/files
CHROMA_PERSIST_DIR=./chroma_db
BM25_PERSIST_DIR=./bm25_db
